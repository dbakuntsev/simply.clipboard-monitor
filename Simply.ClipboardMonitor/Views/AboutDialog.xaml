<Window x:Class="Simply.ClipboardMonitor.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Simply Clipboard Monitor"
        Width="460" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FocusManager.FocusedElement="{Binding ElementName=OkButton}">
    <StackPanel Margin="24,20,24,20" VerticalAlignment="Center">
        <TextBlock Text="Simply Clipboard Monitor"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,8" />
        <TextBlock Text="Copyright &#169; 2026 Dmitry Bakuntsev"
                   Margin="0,0,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Submit Feedback: " VerticalAlignment="Center" />
            <TextBlock VerticalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/dbakuntsev/simply.clipboard-monitor"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    github.com/dbakuntsev/simply.clipboard-monitor/issues
                </Hyperlink>
            </TextBlock>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Source code: " VerticalAlignment="Center" />
            <TextBlock VerticalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/dbakuntsev/simply.clipboard-monitor"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    github.com/dbakuntsev/simply.clipboard-monitor
                </Hyperlink>
            </TextBlock>
        </StackPanel>
        <Button x:Name="OkButton"
                Content="OK"
                Width="80"
                HorizontalAlignment="Right"
                IsDefault="True"
                IsCancel="True"
                Click="OkButton_Click" />
    </StackPanel>
</Window>
