<Window x:Class="Simply.ClipboardMonitor.CrashDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unexpected Error"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <StackPanel Margin="24,20,24,20">

        <TextBlock TextWrapping="Wrap"
                   Margin="0,0,0,12">
            An unexpected error occurred. Details have been written to the error log:
        </TextBlock>

        <TextBlock TextWrapping="Wrap"
                   Margin="0,0,0,20">
            <Hyperlink x:Name="LogFileLink" Click="LogFileLink_Click">
                <Run x:Name="LogFilePathRun" />
            </Hyperlink>
        </TextBlock>

        <Button Content="OK"
                Width="80"
                HorizontalAlignment="Right"
                IsDefault="True"
                IsCancel="True"
                Click="OkButton_Click" />

    </StackPanel>
</Window>
