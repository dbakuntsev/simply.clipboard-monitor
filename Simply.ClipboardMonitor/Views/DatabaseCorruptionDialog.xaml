<Window x:Class="Simply.ClipboardMonitor.DatabaseCorruptionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="24,20,24,20">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Image x:Name="WarningIcon"
                   Width="32" Height="32"
                   VerticalAlignment="Top"
                   Margin="0,0,12,0" />
            <StackPanel>
                <TextBlock x:Name="MessageTextBlock"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                <TextBlock Text="Please choose how to proceed:" />
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="RecoverButton"
                    Content="Recover"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="RecoverButton_Click" />
            <Button Content="Delete and Start Fresh"
                    Width="150"
                    Margin="0,0,8,0"
                    Click="DeleteButton_Click" />
            <Button Content="Disable History Tracking"
                    Width="160"
                    Click="DisableButton_Click" />
        </StackPanel>

    </StackPanel>
</Window>
