<Window x:Class="Simply.ClipboardMonitor.DatabaseRecoveringWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recovering Database"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="24,20,24,20">
        <TextBlock Text="Recovering the history database, please wait…"
                   TextWrapping="Wrap" />
    </StackPanel>
</Window>
