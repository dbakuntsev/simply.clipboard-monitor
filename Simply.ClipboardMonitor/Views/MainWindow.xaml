<Window x:Class="Simply.ClipboardMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Simply.ClipboardMonitor"
        mc:Ignorable="d"
        Title="Simply Clipboard Monitor" Height="700" Width="1080"
        MinHeight="460" MinWidth="800">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerboardBrush"
                      TileMode="Tile"
                      Viewport="0,0,16,16"
                      ViewportUnits="Absolute"
                      Opacity="0.15">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFD0D0D0">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,8,8" />
                                <RectangleGeometry Rect="8,8,8,8" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="L_oad..."    Command="{x:Static local:MainWindow.LoadCommand}" />
                <MenuItem Header="_Save"       Command="{x:Static local:MainWindow.SaveCommand}" />
                <MenuItem Header="Save _As..." Click="MenuItemSaveAs_Click" />
                <Separator />
                <MenuItem Header="_Export Selected Format..." Command="{x:Static local:MainWindow.ExportCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Click="MenuItemExit_Click" />
            </MenuItem>
            <MenuItem Header="_Clipboard" SubmenuOpened="ClipboardMenu_SubmenuOpened">
                <MenuItem x:Name="MenuItemClear" Header="C_lear" Click="MenuItemClear_Click" />
                <MenuItem Header="_Refresh" Command="{x:Static local:MainWindow.RefreshClipboardCommand}" />
                <MenuItem x:Name="MenuItemMonitorChanges"
                          Header="_Monitor Changes"
                          IsCheckable="True"
                          Click="MenuItemMonitorChanges_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Submit _Feedback" Click="MenuItemSubmitFeedback_Click" />
                <MenuItem Header="_About" Click="MenuItemAbout_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" />
            </StatusBarItem>
            <Separator x:Name="FileStatusSeparator" Visibility="Collapsed" />
            <StatusBarItem>
                <TextBlock x:Name="FileStatusText" Foreground="DimGray" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="Clipboard Formats" Grid.Column="0">
                <ListView x:Name="FormatListBox"
                          SelectionChanged="FormatListBox_OnSelectionChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="28" DisplayMemberBinding="{Binding Ordinal}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="OrdinalColumnHeader" Content="#" Tag="Ordinal" />
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="44" DisplayMemberBinding="{Binding FormatNumber}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="IdColumnHeader" Content="ID" Tag="FormatId" />
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="140">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="FormatColumnHeader" Content="Format" Tag="Name" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="76">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="SizeColumnHeader" Content="Size" Tag="ContentSizeValue" />
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ContentSize}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding ContentSize}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <GroupBox Header="Selected Format Content" Grid.Column="2">
                <Grid>
                    <TextBlock x:Name="NoSelectionPanel"
                               Text="Select a clipboard format from the list to see the hex dump and format-specific preview"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="DimGray"
                               Margin="20" />
                    <TabControl x:Name="ContentTabControl" Visibility="Collapsed">
                        <TabItem x:Name="HexTabItem" Header="Hex">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="HexStatusTextBlock"
                                       Foreground="DimGray"
                                       Text="Select a clipboard format to preview." />
                                <ListView x:Name="HexListView"
                                      Grid.Row="2"
                                      FontFamily="Consolas"
                                      FontSize="13"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.ScrollUnit="Item"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListView.View>
                                        <GridView AllowsColumnReorder="False">
                                            <GridViewColumn Header="Offset" Width="90" DisplayMemberBinding="{Binding Offset}" />
                                            <GridViewColumn Header="Hex" Width="380" DisplayMemberBinding="{Binding Hex}" />
                                            <GridViewColumn Header="ASCII" Width="160" DisplayMemberBinding="{Binding Ascii}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="TextTabItem" Header="Text">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Encoding:"
                                                   VerticalAlignment="Center"
                                                   Foreground="DimGray"
                                                   Margin="0,0,6,0" />
                                        <ComboBox x:Name="TextEncodingComboBox"
                                                  Width="230"
                                                  IsEnabled="False"
                                                  SelectionChanged="TextEncodingComboBox_SelectionChanged" />
                                    </StackPanel>
                                    <TextBlock x:Name="TextStatusTextBlock"
                                               Foreground="DimGray"
                                               VerticalAlignment="Center"
                                               Text="Text preview unavailable for this format." />
                                </DockPanel>
                                <TextBox x:Name="TextContentTextBox"
                                     Grid.Row="2"
                                     IsReadOnly="True"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     AcceptsTab="True" />
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="ImageTabItem" Header="Image">
                            <DockPanel Margin="8">
                                <DockPanel DockPanel.Dock="Top"
                                       LastChildFill="False"
                                       Margin="0,0,0,8"
                                       VerticalAlignment="Center">
                                    <StackPanel x:Name="ImageDimensionsStackPanel"
                                            DockPanel.Dock="Left"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                        <TextBlock x:Name="ImageDimensionsWidthTextBlock"
                                                   Text="0px" />
                                        <TextBlock Text="&#x00D7;"
                                                   Margin="1,0,1,0"
                                                   Opacity="0.5" />
                                        <TextBlock x:Name="ImageDimensionsHeightTextBlock"
                                                   Text="0px" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Zoom:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                        <Slider x:Name="ZoomSlider"
                                            Minimum="0.25"
                                            Maximum="8"
                                            Value="1"
                                            Width="160"
                                            IsEnabled="False"
                                            VerticalAlignment="Center"
                                            ValueChanged="ZoomSlider_OnValueChanged" />
                                        <Border Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="ZoomTextBox"
                                                         Width="44"
                                                         BorderThickness="0"
                                                         Padding="2,1"
                                                         TextAlignment="Right"
                                                         VerticalContentAlignment="Center"
                                                         Text="100%"
                                                         IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}"
                                                         LostFocus="ZoomTextBox_LostFocus"
                                                         KeyDown="ZoomTextBox_KeyDown" />
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Vertical">
                                                    <RepeatButton Content="▲"
                                                                  FontSize="6"
                                                                  Padding="3,1"
                                                                  Focusable="False"
                                                                  IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}"
                                                                  Click="ZoomUpButton_Click" />
                                                    <RepeatButton Content="▼"
                                                                  FontSize="6"
                                                                  Padding="3,1"
                                                                  Focusable="False"
                                                                  IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}"
                                                                  Click="ZoomDownButton_Click" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Button Content="Reset"
                                            Margin="8,0,0,0"
                                            Padding="10,2"
                                            Click="ResetZoomButton_OnClick"
                                            IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}" />
                                    </StackPanel>
                                </DockPanel>

                                <Grid>
                                    <TextBlock x:Name="ImageStatusTextBlock"
                                           Foreground="DimGray"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="Image preview unavailable for this format." />
                                    <ScrollViewer x:Name="ImageScrollViewer"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              SizeChanged="ImageScrollViewer_OnSizeChanged"
                                              PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                                              MouseDown="ImageScrollViewer_MouseDown"
                                              MouseUp="ImageScrollViewer_MouseUp"
                                              MouseMove="ImageScrollViewer_MouseMove"
                                              MouseLeave="ImageScrollViewer_MouseLeave">
                                        <Grid MinWidth="{Binding ViewportWidth, ElementName=ImageScrollViewer}"
                                          MinHeight="{Binding ViewportHeight, ElementName=ImageScrollViewer}"
                                          Background="{StaticResource CheckerboardBrush}">
                                            <Image x:Name="ImagePreview"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Stretch="None"
                                               SnapsToDevicePixels="True">
                                                <Image.LayoutTransform>
                                                    <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                                                </Image.LayoutTransform>
                                            </Image>
                                        </Grid>
                                    </ScrollViewer>
                                </Grid>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
