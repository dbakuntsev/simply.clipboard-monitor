<Window x:Class="Simply.ClipboardMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Simply.ClipboardMonitor"
        mc:Ignorable="d"
        Title="Simply Clipboard Monitor" Height="700" Width="1080"
        MinHeight="460" MinWidth="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="L_oad..."    Command="{x:Static local:MainWindow.LoadCommand}" />
                <MenuItem Header="_Save"       Command="{x:Static local:MainWindow.SaveCommand}" />
                <MenuItem Header="Save _As..." Click="MenuItemSaveAs_Click" />
                <Separator />
                <MenuItem Header="_Export Selected Format..." Command="{x:Static local:MainWindow.ExportCommand}" />
                <Separator />
                <MenuItem Header="Se_ttings..." Click="MenuItemSettings_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="MenuItemExit_Click" />
            </MenuItem>
            <MenuItem Header="_Clipboard" SubmenuOpened="ClipboardMenu_SubmenuOpened">
                <MenuItem x:Name="MenuItemClear" Header="C_lear" Click="MenuItemClear_Click" />
                <MenuItem Header="_Refresh" Command="{x:Static local:MainWindow.RefreshClipboardCommand}" />
                <MenuItem x:Name="MenuItemMonitorChanges"
                          Header="_Monitor Changes"
                          IsCheckable="True"
                          Click="MenuItemMonitorChanges_Click" />
                <MenuItem x:Name="MenuItemTrackHistory"
                          Header="Track _History"
                          IsCheckable="True"
                          Click="MenuItemTrackHistory_Click" />
                <MenuItem x:Name="MenuItemPause" Header="_Pause" SubmenuOpened="PauseMenu_SubmenuOpened">
                    <MenuItem x:Name="MenuItemPause1m"  Header="1 minute"   Tag="1"  Click="MenuItemPause_Click" />
                    <MenuItem x:Name="MenuItemPause5m"  Header="5 minutes"  Tag="5"  Click="MenuItemPause_Click" />
                    <MenuItem x:Name="MenuItemPause10m" Header="10 minutes" Tag="10" Click="MenuItemPause_Click" />
                    <MenuItem x:Name="MenuItemPause30m" Header="30 minutes" Tag="30" Click="MenuItemPause_Click" />
                    <MenuItem x:Name="MenuItemPause1h"  Header="1 hour"     Tag="60" Click="MenuItemPause_Click" />
                </MenuItem>
                <MenuItem x:Name="MenuItemResume" Header="R_esume" Click="MenuItemResume_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Submit _Feedback" Click="MenuItemSubmitFeedback_Click" />
                <MenuItem Header="_About" Click="MenuItemAbout_Click" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <!-- Right-aligned items must be declared before left-aligned ones (DockPanel fill rule). -->
            <StatusBarItem DockPanel.Dock="Right">
                <Border x:Name="AutoStartPill"
                        Background="#FFED7D31"
                        CornerRadius="3"
                        Padding="6,1"
                        Margin="0,0,4,0"
                        Visibility="Collapsed">
                    <TextBlock Text="AUTO-START"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="Bold" />
                </Border>
            </StatusBarItem>
            <Separator x:Name="OwnerAutoStartSeparator"
                       DockPanel.Dock="Right"
                       Visibility="Collapsed" />
            <StatusBarItem x:Name="ClipboardOwnerStatusItem"
                           DockPanel.Dock="Right"
                           Visibility="Collapsed">
                <TextBlock x:Name="ClipboardOwnerTextBlock"
                           Foreground="DimGray"
                           ToolTipService.ShowDuration="30000" />
            </StatusBarItem>
            <Separator x:Name="HotkeyStatusSeparator"
                       DockPanel.Dock="Right"
                       Visibility="Collapsed" />
            <StatusBarItem x:Name="HotkeyStatusItem"
                           DockPanel.Dock="Right"
                           Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="HotkeyStatusText" Foreground="DimGray" />
                    <TextBlock x:Name="HotkeyConflictIcon"
                               Text=" ⚠"
                               Foreground="#FFCC44"
                               Visibility="Collapsed"
                               ToolTipService.ShowDuration="30000"
                               ToolTip="This hotkey is already in use by another application" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="StatusText" />
            </StatusBarItem>
            <Separator x:Name="FileStatusSeparator" Visibility="Collapsed" />
            <StatusBarItem>
                <TextBlock x:Name="FileStatusText" Foreground="DimGray" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="LeftPanelGrid" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="0" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>

                <GroupBox Header="Clipboard Formats">
                    <ListView x:Name="FormatListBox"
                              SelectionChanged="FormatListBox_OnSelectionChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <!-- Always reserve the left-border space so text never shifts. -->
                                <Setter Property="BorderThickness" Value="3,0,0,0" />
                                <Setter Property="BorderBrush"     Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FFED7D31" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="28" DisplayMemberBinding="{Binding Ordinal}">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader x:Name="OrdinalColumnHeader" Content="#" Tag="Ordinal" />
                                    </GridViewColumn.Header>
                                </GridViewColumn>
                                <GridViewColumn Width="44" DisplayMemberBinding="{Binding FormatNumber}">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader x:Name="IdColumnHeader" Content="ID" Tag="FormatId" />
                                    </GridViewColumn.Header>
                                </GridViewColumn>
                                <GridViewColumn Width="132">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader x:Name="FormatColumnHeader" Content="Format" Tag="Name" />
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Name}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="76">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader x:Name="SizeColumnHeader" Content="Size" Tag="ContentSizeValue" />
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContentSize}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ContentSize}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>

                <GridSplitter Grid.Row="1"
                              Height="5"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              ResizeBehavior="PreviousAndNext" />

                <!-- Wrapper grid lets the count label overlay the GroupBox header line. -->
                <Grid Grid.Row="2">
                <GroupBox Header="Clipboard History">
                    <DockPanel>
                        <!-- Filter box with placeholder and inline clear button -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBox x:Name="HistoryFilterBox"
                                     TextChanged="HistoryFilterBox_TextChanged"
                                     Padding="3,2,20,2" />
                            <TextBlock Text="Type to filter clipboard history..."
                                       IsHitTestVisible="False"
                                       Foreground="DimGray"
                                       Padding="5,3"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=HistoryFilterBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="18" Height="18"
                                    Margin="0,0,2,0"
                                    Padding="0"
                                    FontSize="11"
                                    Focusable="False"
                                    BorderThickness="0"
                                    ToolTip="Clear filter"
                                    Click="HistoryFilterClearButton_Click">
                                <Button.Content>&#xD7;</Button.Content>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background"  Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Foreground"  Value="DimGray" />
                                        <Setter Property="Cursor"      Value="Arrow" />
                                        <!-- Visible whenever the filter box has text. -->
                                        <Setter Property="Visibility"  Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=HistoryFilterBox}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                        <ListView x:Name="HistoryListView"
                              SelectionChanged="HistoryListView_SelectionChanged"
                              ContextMenuOpening="HistoryContextMenu_Opening"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="HistoryMenuLoadIntoClipboard"
                                              Header="Load into Clipboard"
                                              Click="HistoryLoadIntoClipboard_Click" />
                                    <MenuItem x:Name="HistoryMenuSaveAs"
                                              Header="Save As..."
                                              Click="HistorySaveAs_Click" />
                                    <MenuItem x:Name="HistoryMenuDelete"
                                              Header="Delete"
                                              Click="HistoryDelete_Click" />
                                    <Separator />
                                    <MenuItem Header="Clear All"
                                              Click="HistoryClearAll_Click" />
                                </ContextMenu>
                            </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Date" Width="120"
                                                DisplayMemberBinding="{Binding DateText}" />
                                <GridViewColumn Width="106">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="Formats" />
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- One coloured pill per recognised format category:
                                                 IMG TXT HTML RTF FILE  — OTHER when none match -->
                                            <ItemsControl ItemsSource="{Binding Pills}"
                                                          ToolTip="{Binding FormatsTooltip}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{Binding Background}"
                                                                CornerRadius="3"
                                                                Padding="5,1"
                                                                Margin="0,0,3,0">
                                                            <TextBlock Text="{Binding Label}"
                                                                       Foreground="White"
                                                                       FontSize="10"
                                                                       FontWeight="Bold" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Size" Width="54"
                                                DisplayMemberBinding="{Binding SizeText}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    </DockPanel>
                </GroupBox>
                <!-- Overlays the GroupBox header line; background erases the border behind the text. -->
                <TextBlock x:Name="HistoryCountTextBlock"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                           Foreground="Gray"
                           FontSize="11"
                           Padding="3,0"
                           Margin="0,3,12,0" />
                <!-- Loading overlay: shown while integrity check / schema migration is in progress. -->
                <Border x:Name="HistoryLoadingOverlay"
                        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        Opacity="0.75"
                        Visibility="Collapsed"
                        Panel.ZIndex="10">
                    <TextBlock Text="Loading…"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               FontSize="13" />
                </Border>
                </Grid>
            </Grid>

            <GroupBox Header="Selected Format Content" Grid.Column="2">
                <Grid>
                    <TextBlock x:Name="NoSelectionPanel"
                               Text="Select a clipboard format from the list to see the hex dump and format-specific preview"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="DimGray"
                               Margin="20" />
                    <TabControl x:Name="ContentTabControl" Visibility="Collapsed" />
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
