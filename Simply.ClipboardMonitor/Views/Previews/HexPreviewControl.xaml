<UserControl x:Class="Simply.ClipboardMonitor.Views.Previews.HexPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock x:Name="HexStatusTextBlock"
                   Foreground="DimGray"
                   Text="Select a clipboard format to preview." />
        <ListView x:Name="HexListView"
                  Grid.Row="2"
                  FontFamily="Consolas"
                  FontSize="13"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.ScrollUnit="Item"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView AllowsColumnReorder="False">
                    <GridViewColumn Header="Offset" Width="90"  DisplayMemberBinding="{Binding Offset}" />
                    <GridViewColumn Header="Hex"    Width="380" DisplayMemberBinding="{Binding Hex}" />
                    <GridViewColumn Header="ASCII"  Width="160" DisplayMemberBinding="{Binding Ascii}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
