<UserControl x:Class="Simply.ClipboardMonitor.Views.Previews.ImagePreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="ImagePreviewControl_Loaded">
    <UserControl.Resources>
        <DrawingBrush x:Key="CheckerboardBrush"
                      TileMode="Tile"
                      Viewport="0,0,16,16"
                      ViewportUnits="Absolute"
                      Opacity="0.15">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFD0D0D0">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,8,8" />
                                <RectangleGeometry Rect="8,8,8,8" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>
    <DockPanel Margin="8">
        <DockPanel DockPanel.Dock="Top"
                   LastChildFill="False"
                   Margin="0,0,0,8"
                   VerticalAlignment="Center">
            <StackPanel x:Name="ImageDimensionsStackPanel"
                        DockPanel.Dock="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock x:Name="ImageDimensionsWidthTextBlock"
                           Text="0px" />
                <TextBlock Text="&#x00D7;"
                           Margin="1,0,1,0"
                           Opacity="0.5" />
                <TextBlock x:Name="ImageDimensionsHeightTextBlock"
                           Text="0px" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Zoom:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <Slider x:Name="ZoomSlider"
                        Minimum="0.25"
                        Maximum="8"
                        Value="1"
                        Width="160"
                        IsEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="ZoomSlider_OnValueChanged" />
                <Border Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        BorderBrush="{x:Static SystemColors.ControlDarkBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ZoomTextBox"
                                 Width="44"
                                 BorderThickness="0"
                                 Padding="2,1"
                                 TextAlignment="Right"
                                 VerticalContentAlignment="Center"
                                 Text="100%"
                                 IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}"
                                 LostFocus="ZoomTextBox_LostFocus"
                                 KeyDown="ZoomTextBox_KeyDown" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical">
                            <RepeatButton Content="▲"
                                          FontSize="6"
                                          Padding="3,1"
                                          Focusable="False"
                                          IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}"
                                          Click="ZoomUpButton_Click" />
                            <RepeatButton Content="▼"
                                          FontSize="6"
                                          Padding="3,1"
                                          Focusable="False"
                                          IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}"
                                          Click="ZoomDownButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Button Content="Reset"
                        Margin="8,0,0,0"
                        Padding="10,2"
                        Click="ResetZoomButton_OnClick"
                        IsEnabled="{Binding IsEnabled, ElementName=ZoomSlider}" />
            </StackPanel>
        </DockPanel>

        <Grid>
            <TextBlock x:Name="ImageStatusTextBlock"
                       Foreground="DimGray"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Text="Image preview unavailable for this format." />
            <ScrollViewer x:Name="ImageScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          SizeChanged="ImageScrollViewer_OnSizeChanged"
                          PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                          MouseDown="ImageScrollViewer_MouseDown"
                          MouseUp="ImageScrollViewer_MouseUp"
                          MouseMove="ImageScrollViewer_MouseMove"
                          MouseLeave="ImageScrollViewer_MouseLeave">
                <Grid MinWidth="{Binding ViewportWidth, ElementName=ImageScrollViewer}"
                      MinHeight="{Binding ViewportHeight, ElementName=ImageScrollViewer}"
                      Background="{StaticResource CheckerboardBrush}">
                    <Image x:Name="ImagePreview"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Stretch="None"
                           SnapsToDevicePixels="True">
                        <Image.LayoutTransform>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                        </Image.LayoutTransform>
                    </Image>
                </Grid>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
