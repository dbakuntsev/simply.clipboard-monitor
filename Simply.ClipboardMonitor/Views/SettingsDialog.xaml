<Window x:Class="Simply.ClipboardMonitor.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FocusManager.FocusedElement="{Binding ElementName=MaxEntriesBox}">
    <StackPanel Margin="24,20,24,20">

        <TextBlock Text="Clipboard History"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Maximum number of entries:"
                       VerticalAlignment="Center" />
            <TextBox x:Name="MaxEntriesBox"
                     Grid.Row="0" Grid.Column="1" />

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Maximum database size (MB):"
                       VerticalAlignment="Center" />
            <TextBox x:Name="MaxSizeMbBox"
                     Grid.Row="2" Grid.Column="1" />

            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Current database file size:"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="DbSizeTextBlock"
                       Grid.Row="4" Grid.Column="1"
                       VerticalAlignment="Center" />

            <Button Grid.Row="6" Grid.Column="0"
                    Content="Clear History"
                    HorizontalAlignment="Left"
                    Width="110"
                    Click="ClearHistoryButton_Click" />
        </Grid>

        <Separator Margin="0,16,0,0" />

        <TextBlock Text="Application"
                   FontWeight="SemiBold"
                   Margin="0,16,0,12" />

        <CheckBox x:Name="MinimizeToTrayCheckBox"
                  Content="Minimize to System Tray"
                  Margin="0,0,0,8" />

        <CheckBox x:Name="StartAtLoginCheckBox"
                  Content="Start at login"
                  Margin="0,0,0,8" />

        <CheckBox x:Name="StartMinimizedCheckBox"
                  Content="Start minimized"
                  Margin="0,0,0,0" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="OK"
                    Width="80"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Margin="0,0,8,0" />
            <Button Content="Cancel"
                    Width="80"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>

    </StackPanel>
</Window>
